datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id            String         @id @default(uuid())
  email         String         @unique
  passwordHash  String
  fullName      String
  phoneNumber   String?
  role          String         @default("STUDENT") // STUDENT, ALUMNI, MENTOR, ADMIN
  memberId      String?        @unique
  publicKey           String?
  encryptedPrivateKey String?
  keySalt             String?
  keyIv               String?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  
  edPoints      Int            @default(50)
  pointTransactions PointTransaction[]
  
  profile       Profile?
  resumes       Resume[]
  applications  Application[]
  sentMessages  Message[]      @relation("SentMessages")
  recvMessages  Message[]      @relation("ReceivedMessages")
  connections   Connection[]   @relation("UserConnections")
  connectedTo   Connection[]   @relation("FriendConnections")
  posts         Post[]
  comments      Comment[]
  chats         AIChat[]
  notifications Notification[]
  ambassadorApplications AmbassadorApplication[]
}

model Profile {
  id             String        @id @default(uuid())
  userId         String        @unique
  user           User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  collegeName    String
  degree         String
  branch         String
  graduationYear Int
  headline       String?
  interests      String        @default("[]") // JSON string of interests
  goals          String        @default("[]") // JSON string of goals
  readinessScore Int           @default(0)
  bio            String?
  avatarUrl      String?
  portfolioUrl   String?       @unique // Public URL: u/username
  dob            DateTime?
  latitude       Float?
  longitude      Float?
  isOnboarded    Boolean       @default(false)
  
  projects       Project[]
  experience     Experience[]
  certifications Certification[]
  skills         Skill[]
}

model Resume {
  id            String         @id @default(uuid())
  userId        String
  user          User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  fileName      String
  fileUrl       String
  atsScore      Int            @default(0)
  keywordReport String         @default("[]") // JSON string of suggestions
  uploadedAt    DateTime       @default(now())

  @@index([userId])
}

model Project {
  id          String           @id @default(uuid())
  profileId   String
  profile     Profile          @relation(fields: [profileId], references: [id], onDelete: Cascade)
  title       String
  description String
  technologies String          @default("[]") // JSON string of technologies
  projectUrl  String?
  githubUrl   String?

  @@index([profileId])
}

model Experience {
  id           String          @id @default(uuid())
  profileId    String
  profile      Profile         @relation(fields: [profileId], references: [id], onDelete: Cascade)
  company      String
  role         String
  startDate    DateTime
  endDate      DateTime?
  description  String

  @@index([profileId])
}

model Certification {
  id          String           @id @default(uuid())
  profileId   String
  profile     Profile          @relation(fields: [profileId], references: [id], onDelete: Cascade)
  name        String
  issuer      String
  issueDate   DateTime
  expiryDate  DateTime?
  credentialId String?
  courseId    String?          // Associated course in Learning Center

  @@index([profileId])
}

model Skill {
  id        String             @id @default(uuid())
  profileId String
  profile   Profile            @relation(fields: [profileId], references: [id], onDelete: Cascade)
  name      String

  @@index([profileId])
}

model Opportunity {
  id            String         @id @default(uuid())
  title         String
  companyName   String
  companyType   String         @default("STARTUP") // STARTUP, ENTERPRISE
  location      String
  salary        String?
  remote        Boolean        @default(false)
  type          String         // JOB, INTERNSHIP, HACKATHON, SCHOLARSHIP
  skillsRequired String        @default("[]") // JSON string of skills
  description   String
  externalLink  String?
  createdAt     DateTime       @default(now())
  
  applications  Application[]
}

model Application {
  id            String            @id @default(uuid())
  userId        String
  user          User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  opportunityId String
  opportunity   Opportunity       @relation(fields: [opportunityId], references: [id], onDelete: Cascade)
  status        String            @default("APPLIED") // APPLIED, SHORTLISTED, INTERVIEW, OFFER, REJECTED
  appliedAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt

  @@unique([userId, opportunityId])
  @@index([opportunityId])
}

model Connection {
  id          String           @id @default(uuid())
  senderId    String
  sender      User             @relation("UserConnections", fields: [senderId], references: [id], onDelete: Cascade)
  receiverId  String
  receiver    User             @relation("FriendConnections", fields: [receiverId], references: [id], onDelete: Cascade)
  status      String           // PENDING, CONNECTED
  createdAt   DateTime         @default(now())

  @@unique([senderId, receiverId])
  @@index([receiverId])
}

model Message {
  id         String            @id @default(uuid())
  senderId   String
  sender     User              @relation("SentMessages", fields: [senderId], references: [id], onDelete: Cascade)
  receiverId String
  receiver   User              @relation("ReceivedMessages", fields: [receiverId], references: [id], onDelete: Cascade)
  text       String
  textForSender   String?
  textForReceiver String?
  read       Boolean           @default(false)
  createdAt  DateTime          @default(now())

  @@index([senderId])
  @@index([receiverId])
}

model Notification {
  id        String             @id @default(uuid())
  userId    String
  user      User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  title     String
  text      String
  read      Boolean            @default(false)
  createdAt DateTime           @default(now())

  @@index([userId])
}

model Course {
  id            String         @id @default(uuid())
  title         String
  description   String
  durationHours Int
  skillsEarned  String         @default("[]") // JSON string of skills
  category      String
}

model Post {
  id        String             @id @default(uuid())
  userId    String
  user      User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  title     String
  content   String
  likesCount Int               @default(0)
  createdAt DateTime           @default(now())
  
  comments  Comment[]

  @@index([userId])
}

model Comment {
  id        String             @id @default(uuid())
  postId    String
  post      Post               @relation(fields: [postId], references: [id], onDelete: Cascade)
  userId    String
  user      User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  content   String
  createdAt DateTime           @default(now())

  @@index([postId])
  @@index([userId])
}

model AIChat {
  id         String            @id @default(uuid())
  userId     String
  user       User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  title      String
  messages   String            @default("[]") // JSON string of array messages
  createdAt  DateTime          @default(now())
  updatedAt  DateTime          @updatedAt

  @@index([userId])
}

model DataLog {
  id        String   @id @default(uuid())
  type      String   // LOGIN_SUCCESS, LOGIN_FAILURE, SIGNUP, PASSWORD_RESET, BULK_ANNOUNCEMENT
  email     String
  ipAddress String?
  details   String?  // Additional details, e.g. role assigned, failure reason
  createdAt DateTime @default(now())
}

model PasswordResetOTP {
  id        String   @id @default(uuid())
  email     String   @unique
  code      String
  expiresAt DateTime
  createdAt DateTime @default(now())
}

model PointTransaction {
  id          String   @id @default(uuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  points      Int      // e.g. +50, +10, -200
  description String   // e.g. "Welcome Signup Reward", "Daily Login Bonus", etc.
  createdAt   DateTime @default(now())

  @@index([userId])
}

model AmbassadorApplication {
  id          String   @id @default(uuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  name        String
  email       String
  phone       String
  whatsapp    String
  linkedin    String
  collegeName String
  course      String
  year        String
  rollNumber  String
  city        String
  status      String   @default("PENDING") // PENDING, APPROVED, REJECTED
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([userId])
}

